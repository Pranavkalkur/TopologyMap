{
  "manifest_version": 3,
  "name": "TopologyMap",
  "version": "1.0.0",
  "description": "Live HTTP Dependency Graph — Visualize outgoing network requests as an interactive topology map.",
  "action": {
    "default_title": "Open TopologyMap"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": [
    "webRequest",
    "sidePanel",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
